{
  "name": "local-agent-profile-rag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node src/server.js",
    "dev:web": "vite --host 0.0.0.0",
    "start": "node src/server.js",
    "build": "vite build",
    "test": "node --test tests/*.test.js",
    "eval:rag": "node scripts/eval-rag.js",
    "crawl:confluence": "node scripts/crawl-confluence.mjs",
    "desktop": "npm run build && electron .",
    "desktop:dist:win": "npm run build && electron-builder --win",
    "desktop:dist:mac": "npm run build && electron-builder --mac",
    "py:deps": "uv venv --python 3.12 .venv && uv pip install --python .venv/bin/python -r requirements-worker.txt",
    "py:embedding-deps": "uv venv --python 3.12 .venv && uv pip install --python .venv/bin/python -r requirements-embedding.txt",
    "py:check": "if [ -x .venv/bin/python ]; then .venv/bin/python workers/ingest.py --self-check; else python3 workers/ingest.py --self-check; fi"
  },
  "build": {
    "appId": "com.ark.local-rag",
    "productName": "ARK",
    "asar": false,
    "files": [
      "electron/**",
      "src/**",
      "dist/client/**",
      "workers/**",
      ".env.local-example",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^9.1.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "fastify": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
