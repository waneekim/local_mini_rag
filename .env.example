# ARK 호스트 연결 기본값 — 회사 LLM · 임베딩 서버
#
# 사용법: 이 파일을 .env 로 복사한 뒤 서버를 실행하세요.
#   cp .env.example .env && npm run build && npm start
# 여기 값들은 ⚙️ 연결 설정에 "기본" 프리셋으로 자동 등록됩니다.
#
# API Key는 여기에 넣지 않습니다(레포에 커밋 방지).
# 브라우저 ⚙️ 연결 설정(관리자 인증 후)에서 직접 입력하세요.

# --- LLM (OpenAI 호환 chat + vision 겸용) ---
# 엔드포인트는 {LLM_BASE_URL}/chat/completions 로 호출됩니다 → 반드시 /v1 까지 포함!
LLM_BASE_URL=http://10.250.122.177:9000/v1
LLM_MODEL=llm-large
# 우리 LLM이 비전 분석 겸용이라 같은 모델을 비전에 사용 (별도 VL 모델이 있으면 교체)
VISION_MODEL=llm-large
LLM_MAX_TOKENS=1024
# 사내 vLLM thinking 모드 끄기 (openai-python의 extra_body 내용을 요청 최상위로 병합)
LLM_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}
# LLM_API_KEY=            # 브라우저에서 입력

# --- 임베딩 ---
EMBEDDINGS_URL=http://10.250.122.177:47270/v1/embeddings
EMBEDDINGS_MODEL=qwen3-embedding-4b
# EMBEDDINGS_API_KEY=     # 비우면 LLM_API_KEY 를 사용

# --- 중앙 공유 호스트로 쓸 때(선택) ---
# 설정하면 읽기는 공개, 모든 수정은 이 암호 필요. 개인 로컬이면 비워둠.
# ARK_ADMIN_TOKEN=원하는암호
# HOST=0.0.0.0
# PORT=8787
