# ARK 호스트 연결 기본값 — 회사 LLM · 임베딩 서버
#
# 사용법: 이 파일을 .env 로 복사한 뒤 서버를 실행하세요.
#   cp .env.example .env && npm run build && npm start
# 여기 값들은 ⚙️ 연결 설정에 "기본" 프리셋으로 자동 등록됩니다.
#
# API Key는 여기에 넣지 않습니다(레포에 커밋 방지).
# 브라우저 ⚙️ 연결 설정(관리자 인증 후)에서 직접 입력하세요.

# --- LLM (OpenAI 호환 chat + vision 겸용) ---
# 엔드포인트는 {LLM_BASE_URL}/chat/completions 로 호출됩니다 → 반드시 /v1 까지 포함!
LLM_BASE_URL=http://10.250.122.177:9000/v1
LLM_MODEL=llm-large
# 우리 LLM이 비전 분석 겸용이라 같은 모델을 비전에 사용 (별도 VL 모델이 있으면 교체)
VISION_MODEL=llm-large
LLM_MAX_TOKENS=1024
# 사내 vLLM thinking 모드 끄기 (openai-python의 extra_body 내용을 요청 최상위로 병합)
LLM_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}
# LLM_API_KEY=            # 브라우저에서 입력

# --- Gauss OpenAPI chat-only provider (선택) ---
# 삼성 사내 Gauss OpenAPI(genai-openapi.sec.samsung.net)를 chat LLM으로 쓸 때.
# LLM_PROVIDER=gauss-openapi 로 켜거나 앱 설정에서 Gauss 프리셋을 선택하세요.
# 토큰은 비밀값 — 실제 값은 .env 또는 로컬 data/settings.json 에만 두세요.
# 비전(이미지) 요청은 미지원(chat 전용). 대형 RAG 프롬프트는 문자수 가드레일로 자동 클리핑.
# LLM_PROVIDER=gauss-openapi
# GAUSS_BASE_URL=https://genai-openapi.sec.samsung.net/dxhq/trial/api-chat
# GAUSS_MODEL_ID=0196f1fc-2858-70a9-a232-74dbddb971d0
# GAUSS_CLIENT_TOKEN=
# GAUSS_OPENAPI_TOKEN=Bearer ...
# GAUSS_USER_EMAIL=name@example.com
# GAUSS_STREAM=1
# GAUSS_TIMEOUT_MS=240000
# GAUSS_USE_SYSTEM_PROMPT=0
# GAUSS_MAX_TOKENS=512
# 대형 RAG 프롬프트 안정성 가드레일(문자수 상한):
# GAUSS_SYSTEM_MAX_CHARS=6000
# GAUSS_CONTEXT_MAX_CHARS=9000
# GAUSS_HISTORY_MAX_CHARS=4000
# GAUSS_CONTENT_MAX_CHARS=18000

# --- 임베딩 ---
EMBEDDINGS_URL=http://10.250.122.177:47270/v1/embeddings
EMBEDDINGS_MODEL=qwen3-embedding-4b
# EMBEDDINGS_API_KEY=     # 비우면 LLM_API_KEY 를 사용
# qwen3-embedding은 질문에 instruction을 자동으로 붙입니다(모델명으로 감지). 바꾸려면:
# RAG_EMBED_QUERY_INSTRUCTION=Given a search query, retrieve relevant passages that answer the query

# --- 검색 품질 튜닝 (선택) ---
# 관련성 최저선: 이 점수 미만 청크는 버려 LLM이 엉뚱한 근거로 답하지 않게 함(0=끔). qwen3면 0.25~0.4 권장
# RAG_MIN_SCORE=0.3
# 청크 크기/겹침(문자 수). 표·규정처럼 조밀하면 800/120, 서술형이면 1200/150
# RAG_CHUNK_SIZE=1200
# RAG_CHUNK_OVERLAP=150
# 전처리(구조화): PDF 페이지별 처리 시 최대 페이지 수(스캔 페이지는 비전 모델로 복원)
# RAG_PREPROCESS_MAX_PAGES=30
# 전처리 출력 토큰/타임아웃 동적 튜닝 — 문서가 길수록 출력 예산·시간을 자동 확대.
# 텍스트: base(MAX_TOKENS)에서 입력 길이×RATIO 로 추정, MAX_TOKENS_CAP 까지 상한.
# RAG_PREPROCESS_MAX_TOKENS=2048
# RAG_PREPROCESS_MAX_TOKENS_CAP=16384
# RAG_PREPROCESS_OUTPUT_TOKEN_RATIO=1.35
# 이미지/스크린샷 구조화 출력 예산(0=max_tokens 생략):
# RAG_PREPROCESS_IMAGE_MAX_TOKENS=16384
# 타임아웃(ms): base + (추가 토큰/1k)×PER_1K, CAP 까지 상한.
# RAG_PREPROCESS_TIMEOUT_MS=60000
# RAG_PREPROCESS_TIMEOUT_MS_CAP=240000
# RAG_PREPROCESS_TIMEOUT_MS_PER_1K_TOKENS=5000
# 전처리 요청 본문 추가필드(기본: enable_thinking:false). {} 로 LLM_EXTRA_BODY 그대로 상속:
# RAG_PREPROCESS_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}
# RAG_PREPROCESS_DISABLE_THINKING=1

# --- URL 소스 임포트 (자동 폴백) ---
# URL 추가 시 일반 fetch → (부족하면) 헤드리스 브라우저 렌더 → (필요시) 스크린샷+비전
# 순으로 자동 시도. 브라우저 단계는 사내 SSO/JS 렌더 페이지(Confluence 등)에 필요.
# RAG_URL_MIN_TEXT=120          # 이 글자수 미만이면 "내용부족"으로 보고 다음 방법 시도
# RAG_BROWSER_PATH=             # Chrome/Edge 실행 파일 경로(미지정 시 표준 위치 자동 탐색)
# RAG_BROWSER_DEBUG_PORT=9223
# RAG_BROWSER_TEXT_WAIT_MS=45000        # 느린 SSO 페이지 텍스트 렌더 대기
# RAG_BROWSER_TEXT_MIN_SETTLE_MS=2500
# RAG_BROWSER_TEXT_STABLE_READS=3
# RAG_BROWSER_LOAD_TIMEOUT_MS=45000

# --- 리랭커 (정확도 최상) ---
# 임베딩으로 넓게 뽑은 후보를 정밀 재정렬. 현재는 별도 리랭커 서버가 없으므로
# 기존 LLM으로 재정렬(검색마다 LLM 호출 1회 추가 → 약간 느려짐). 실패 시 임베딩 순서로 폴백.
RAG_RERANK=llm
# 나중에 전용 리랭커(qwen3-reranker 등)를 배포하면 위 한 줄을 지우고 아래로 교체(더 빠르고 정확):
# RERANK_URL=http://10.250.122.177:PORT/v1/rerank
# RERANK_MODEL=qwen3-reranker-4b
# 공통(선택): RAG_RERANK_CANDIDATES=24  RAG_RERANK_MIN_SCORE=0.3  RERANK_API_KEY=
# HuggingFace TEI 서버에 붙일 때만: 요청 형식을 {query, texts}로 전환
# RERANK_STYLE=tei

# --- 집 PC 구성 예시 (LM Studio + llama.cpp 리랭커) ---
# LM Studio는 chat/embeddings만 서빙하고 /rerank 가 없으므로, 리랭커는 llama.cpp로 따로 띄웁니다:
#   llama-server -m bge-reranker-v2-m3-Q8_0.gguf --reranking --port 8012
# (bge-reranker-v2-m3: 다국어·한국어 강함, 양자화 시 1GB 미만 — CPU로도 동작)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=qwen2.5-7b-instruct
# EMBEDDINGS_URL=http://localhost:1234/v1/embeddings
# EMBEDDINGS_MODEL=text-embedding-bge-m3
# RERANK_URL=http://localhost:8012/v1/rerank
# RERANK_MODEL=bge-reranker-v2-m3
# ↑ RERANK_URL을 쓰면 위의 RAG_RERANK=llm 줄은 지우거나 주석 처리하세요.

# --- 중앙 공유 호스트로 쓸 때(선택) ---
# 설정하면 읽기는 공개, 모든 수정은 이 암호 필요. 개인 로컬이면 비워둠.
# ARK_ADMIN_TOKEN=원하는암호
# HOST=0.0.0.0
# PORT=8787
