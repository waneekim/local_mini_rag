# 내 PC 로컬 설정 — LM Studio 기본값
#
# LM Studio(https://lmstudio.ai)를 설치하고 채팅 모델·임베딩 모델을 로드한 뒤
# Local Server(기본 포트 1234)를 켜면 아래 값 그대로 바로 동작합니다.
# API Key는 필요 없습니다.
#
# 사용법:  cp .env.local-example .env && npm run build && npm start
# (scripts/setup-mac.command 또는 scripts/setup-windows.bat 를 쓰면 자동으로 복사됩니다)

# --- LLM (LM Studio Local Server) ---
LLM_BASE_URL=http://localhost:1234/v1
# LM Studio에 로드한 채팅 모델 이름으로 바꾸세요 (예: qwen2.5-7b-instruct)
LLM_MODEL=qwen2.5-7b-instruct
LLM_MAX_TOKENS=1024
# 비전 겸용 모델(VL)을 로드했다면 지정 — 스크린샷 첨부·이미지 구조화(전처리)에 사용
# VISION_MODEL=qwen2-vl-7b-instruct

# --- 임베딩 (LM Studio 같은 서버) ---
EMBEDDINGS_URL=http://localhost:1234/v1/embeddings
# LM Studio에 로드한 임베딩 모델 이름 (한국어 추천: bge-m3 계열)
EMBEDDINGS_MODEL=text-embedding-bge-m3

# --- 리랭커 (선택 · 정확도 향상) ---
# 별도 서버 없이 기존 LLM으로 재정렬. llama.cpp 리랭커를 띄우면 RERANK_URL로 교체(README 참고).
RAG_RERANK=llm

# --- 검색 품질 (선택) ---
# RAG_MIN_SCORE=0.3
